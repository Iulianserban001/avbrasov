rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is the admin
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'CZdb17bREbhYZF9g6mRzjqx6a7C2';
    }

    // Public content (Pages, Services, Localities) - readable by anyone, writable by admin
    match /pages/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /services/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /localities/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Protected content (Users, Links, Logs, Settings) - only readable/writable by admin
    match /users/{document=**} {
      allow read, write: if isAdmin();
    }
    match /internal_links/{document=**} {
      allow read, write: if isAdmin();
    }
    match /site_settings/{document=**} {
      allow read, write: if isAdmin();
    }
    match /audit_log/{document=**} {
      allow read, write: if isAdmin();
    }

    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
